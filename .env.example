# --- Fase 2: detección automática de marcas de agua con IA (opcional) ---
# Clave de la API de Gemini (https://aistudio.google.com/apikey).
# Es una variable de SERVIDOR (sin prefijo VITE_): nunca se expone al navegador.
# En Vercel: Settings → Environment Variables → GEMINI_API_KEY.
# Sin esta clave, la app funciona igual con selección manual de zonas.
GEMINI_API_KEY=

# Modelo de Gemini a usar para la detección (opcional)
GEMINI_MODEL=gemini-2.5-flash

# Tamaño máximo de archivo en bytes (500 MB por defecto)
VITE_MAX_FILE_SIZE=524288000

# URL de un backend de procesamiento completo (opcional, no necesario:
# el procesamiento ocurre en el navegador con ffmpeg.wasm)
VITE_API_URL=
